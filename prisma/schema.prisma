generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Rol {
  SUPER_ADMIN
  ADMINISTRADOR
  OPERADOR
  DOCENTE
  MONITOR
}

enum CategoriaDocente {
  PRINCIPAL
  ASOCIADO
  AUXILIAR
  CONTRATADO
  INVITADO
}

enum DedicacionDocente {
  TIEMPO_COMPLETO_40H
  TIEMPO_PARCIAL_20H
  DEDICACION_EXCLUSIVA
}

enum TipoSede {
  SEDE_CENTRAL
  SEDE_DESCENTRALIZADA
}

enum SedeDescentralizada {
  CASAS
  HUAMACHUCO
  TAYABAMBA
  SANTIAGO_DE_CHUCO
  OTRA
}

enum TipoAmbiente {
  AULA
  LABORATORIO
  AUDITORIO
  SALA_CONFERENCIAS
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum EstadoPeriodo {
  BORRADOR
  ACTIVO
  FINALIZADO
  ARCHIVADO
}

enum EstadoHorario {
  BORRADOR
  SELECCION_TEMPORAL
  CONFIRMADO
  PUBLICADO
  CANCELADO
}

enum EstadoVentana {
  PROGRAMADA
  ABIERTA
  EN_CURSO
  CERRADA
  CANCELADA
}

enum EstadoAtencion {
  ESPERANDO
  EN_ATENCION
  ATENDIDO
  AUSENTE
  CANCELADO
}

enum TipoNotificacion {
  SELECCION_HORARIO
  CONFIRMACION_HORARIO
  CAMBIO_HORARIO
  VENTANA_ATENCION
  RECORDATORIO
  INCOMPATIBILIDAD_DETECTADA
  SISTEMA
}

enum CanalNotificacion {
  CORREO
  WHATSAPP
  TELEGRAM
  SISTEMA
}

enum EstadoNotificacion {
  PENDIENTE
  ENVIADA
  FALLIDA
  LEIDA
  CANCELADA
}

enum PrioridadNotificacion {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum TipoCargoAdministrativo {
  DECANO
  DIRECTOR_DE_ESCUELA
  DIRECTOR_DE_POSTGRADO
  JEFE_DE_DEPARTAMENTO
  PROFESOR_SECRETARIO
  JEFE_DE_OFICINA_GENERAL
  DIRECTOR_DE_CENTRO_PRODUCCION
  OTRO
}

enum TipoBeca {
  MAESTRIA
  DOCTORADO
  SEGUNDA_ESPECIALIDAD
}

enum TipoActividadNoLectiva {
  PREPARACION_Y_EVALUACION
  CONSEJERIA
  INVESTIGACION
  CAPACITACION
  ACTIVIDADES_DE_GOBIERNO
  ACTIVIDADES_DE_ADMINISTRACION
  ASESORIA_DE_TESIS
  RESPONSABILIDAD_SOCIAL_UNIVERSITARIA
  COMITES_TECNICOS_Y_COMISIONES
}

enum TipoComponente {
  TEORIA
  PRACTICA
  LABORATORIO
}

enum TipoReglaValidacion {
  CRUCE_DOCENTE
  CRUCE_AULA
  EXCEDE_LIMITE_SEDE_DESCENTRALIZADA
  INCOMPATIBILIDAD_CARGO
  INCOMPATIBILIDAD_BECA
  FALTA_COMISION_SERVICIO
  SUPERA_HORAS_MAX_DIARIAS
  SUPERA_HORAS_CONTINUAS
  DESCANSO_INSUFICIENTE
}

enum EstadoIncumplimiento {
  DETECTADO
  EN_REVISION
  CONFIRMADO
  RECHAZADO
  SANCIONADO
}

// ============================================
// MODELOS PRINCIPALES
// ============================================

model Usuario {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  nombre        String
  apellidos     String
  rol           Rol       @default(DOCENTE)
  activo        Boolean   @default(true)
  verificado    Boolean   @default(false)
  tokenVersion  Int       @default(0)
  ultimoAcceso  DateTime?
  
  docente       Docente?
  sesiones      Sesion[]
  notificaciones Notificacion[]
  auditorias    RegistroAuditoria[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([rol])
  @@map("usuarios")
}

model Sesion {
  id           String   @id @default(uuid())
  usuarioId    String
  token        String   @unique
  refreshToken String   @unique
  expiraEn     DateTime
  ipAddress    String?
  userAgent    String?
  activa       Boolean  @default(true)
  
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([usuarioId])
  @@index([token])
  @@index([refreshToken])
  @@map("sesiones")
}

// ============================================
// DOCENTES Y DATOS PERSONALES
// ============================================

model Docente {
  id              String    @id @default(uuid())
  usuarioId       String    @unique
  codigo          String    @unique
  categoria       CategoriaDocente
  dedicacion      DedicacionDocente @default(TIEMPO_COMPLETO_40H)
  departamento    String?
  telefono        String?
  whatsapp        String?
  telegramId      String?
  verificadoWhatsapp  Boolean @default(false)
  verificadoTelegram  Boolean @default(false)
  fechaIngreso    DateTime?
  
  // Relaciones
  usuario         Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  preferenciasNotificacion PreferenciasNotificacion?
  horarios        Horario[]
  cursos          CursoDocente[]
  ventanasAtendidas AtencionVentana[]
  disponibilidad  DisponibilidadDocente[]
  cargos          CargoAdministrativo[]
  becas           BecaDocente[]
  comisiones      ComisionServicio[]
  declaracionesNoLectiva DeclaracionNoLectiva[]
  incumplimientos Incumplimiento[]
  distribucionesNoLectiva DistribucionNoLectiva[]
  comisionesReemplazo ComisionServicio[] @relation("DocenteReemplazo")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([codigo])
  @@index([categoria])
  @@index([dedicacion])
  @@index([departamento])
  @@map("docentes")
}

// ============================================
// CARGOS ADMINISTRATIVOS
// ============================================

model CargoAdministrativo {
  id          String                @id @default(uuid())
  docenteId   String
  tipoCargo   TipoCargoAdministrativo
  fechaInicio DateTime
  fechaFin    DateTime?
  activo      Boolean               @default(true)
  resolucion  String?
  observaciones String?
  
  docente     Docente               @relation(fields: [docenteId], references: [id], onDelete: Cascade)

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([docenteId, activo])
  @@index([tipoCargo])
  @@map("cargos_administrativos")
}

// ============================================
// BECAS DE ESTUDIO
// ============================================

model BecaDocente {
  id          String        @id @default(uuid())
  docenteId   String
  tipoBeca    TipoBeca
  fechaInicio DateTime
  fechaFin    DateTime?
  institucion String?
  resolucion  String?
  activo      Boolean       @default(true)
  
  docente     Docente       @relation(fields: [docenteId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([docenteId, activo])
  @@index([tipoBeca])
  @@map("becas_docentes")
}

// ============================================
// COMISIONES DE SERVICIO (Para sedes especiales)
// ============================================

model ComisionServicio {
  id                String              @id @default(uuid())
  docenteId         String
  sedeDestino       SedeDescentralizada
  fechaInicio       DateTime
  fechaFin          DateTime
  licenciaDocumento String              // N° de resolución/licencia
  docenteReemplazoId String?            // Docente que asume su carga en sede central
  activo            Boolean             @default(true)
  
  docente           Docente             @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  docenteReemplazo  Docente?            @relation("DocenteReemplazo", fields: [docenteReemplazoId], references: [id])

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([docenteId, activo])
  @@index([sedeDestino])
  @@index([docenteReemplazoId])
  @@map("comisiones_servicio")
}

// ============================================
// CURSOS Y GRUPOS
// ============================================

model Curso {
  id              String    @id @default(uuid())
  codigo          String    @unique
  nombre          String
  creditos        Int
  horasTeoria     Int
  horasPractica   Int
  horasLaboratorio Int    @default(0)
  ciclo           Int
  planEstudios    String?
  activo          Boolean   @default(true)
  
  grupos          Grupo[]
  cursosDocente   CursoDocente[]
  horarios        Horario[]
  matriculas      Matricula[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([codigo])
  @@index([ciclo])
  @@index([activo])
  @@map("cursos")
}

model Grupo {
  id          String   @id @default(uuid())
  cursoId     String
  nombre      String
  capacidad   Int
  activo      Boolean  @default(true)
  
  curso       Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  horarios    Horario[]
  matriculas  Matricula[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cursoId])
  @@unique([cursoId, nombre])
  @@map("grupos")
}

model CursoDocente {
  id            String   @id @default(uuid())
  cursoId       String
  docenteId     String
  horasAsignadas Int    @default(0)
  activo        Boolean  @default(true)
  
  curso         Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  docente       Docente  @relation(fields: [docenteId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([cursoId, docenteId])
  @@index([docenteId])
  @@map("cursos_docentes")
}

// ============================================
// AMBIENTES
// ============================================

model Ambiente {
  id              String    @id @default(uuid())
  codigo          String    @unique
  nombre          String
  tipo            TipoAmbiente
  capacidad       Int
  ubicacion       String?
  sede            TipoSede  @default(SEDE_CENTRAL)
  sedeDescentralizadaRef SedeDescentralizada?
  activo          Boolean   @default(true)
  
  horarios        Horario[]
  mantenimientos  MantenimientoAmbiente[]
  restricciones   RestriccionAmbiente[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tipo])
  @@index([sede])
  @@index([activo])
  @@map("ambientes")
}

// ============================================
// PERIODOS ACADÉMICOS
// ============================================

model PeriodoAcademico {
  id              String        @id @default(uuid())
  nombre          String
  fechaInicio     DateTime
  fechaFin        DateTime
  estado          EstadoPeriodo @default(BORRADOR)
  activo          Boolean       @default(false)
  
  horarios        Horario[]
  ventanas        VentanaAtencion[]
  matriculas      Matricula[]
  configuraciones ConfiguracionPeriodo?
  distribucionesNoLectiva DistribucionNoLectiva[]
  declaracionesNoLectiva DeclaracionNoLectiva[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([estado])
  @@index([activo])
  @@map("periodos_academicos")
}

// ============================================
// HORARIOS (CORE)
// ============================================

model Horario {
  id              String        @id @default(uuid())
  periodoId       String
  cursoId         String
  docenteId       String
  grupoId         String?
  ambienteId      String?
  sede            TipoSede      @default(SEDE_CENTRAL)
  sedeDescentralizadaRef SedeDescentralizada?
  diaSemana       DiaSemana?
  horaInicio      String?
  horaFin         String?
  tipoComponente  TipoComponente @default(TEORIA)
  estado          EstadoHorario @default(BORRADOR)
  publicado       Boolean       @default(false)
  
  // Metadatos
  creadoPor       String?
  fechaCreacion   DateTime      @default(now())
  confirmadoPor   String?
  fechaConfirmacion DateTime?
  
  // Relaciones
  periodo         PeriodoAcademico @relation(fields: [periodoId], references: [id])
  curso           Curso            @relation(fields: [cursoId], references: [id])
  docente         Docente          @relation(fields: [docenteId], references: [id])
  grupo           Grupo?           @relation(fields: [grupoId], references: [id])
  ambiente        Ambiente?        @relation(fields: [ambienteId], references: [id])
  
  validaciones    ValidacionHorario[]
  incumplimientos Incumplimiento[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // NOTA: Las constraints únicas se validan a nivel de aplicación
  // debido a la necesidad de lógica compleja de superposición parcial
  
  @@index([periodoId, estado])
  @@index([docenteId, periodoId])
  @@index([ambienteId, periodoId])
  @@index([sede])
  @@map("horarios")
}

// ============================================
// DECLARACIÓN DE CARGA NO LECTIVA
// ============================================

model DeclaracionNoLectiva {
  id              String    @id @default(uuid())
  docenteId       String
  periodoId       String
  fechaDeclaracion DateTime  @default(now())
  totalHoras      Int       // Suma de todas las actividades, debe cuadrar con dedicación
  observaciones   String?
  
  docente         Docente   @relation(fields: [docenteId], references: [id])
  periodo         PeriodoAcademico @relation(fields: [periodoId], references: [id])
  items           DeclaracionNoLectivaItem[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([docenteId, periodoId])
  @@map("declaraciones_no_lectiva")
}

model DeclaracionNoLectivaItem {
  id              String                  @id @default(uuid())
  declaracionId   String
  tipoActividad   TipoActividadNoLectiva
  horasSemanales  Int
  descripcion     String?
  metadata        Json?                   // Para datos adicionales (ej: N° de alumnos, código de proyecto, etc.)
  
  declaracion     DeclaracionNoLectiva    @relation(fields: [declaracionId], references: [id], onDelete: Cascade)
  distribuciones  DistribucionNoLectiva[]

  createdAt       DateTime                @default(now())

  @@map("declaraciones_no_lectiva_items")
}

model DistribucionNoLectiva {
  id                 String                   @id @default(uuid())
  docenteId          String
  periodoId          String
  declaracionItemId  String
  diaSemana          DiaSemana
  horaInicio         String
  horaFin            String
  
  docente            Docente                  @relation(fields: [docenteId], references: [id])
  periodo            PeriodoAcademico         @relation(fields: [periodoId], references: [id])
  declaracionItem    DeclaracionNoLectivaItem @relation(fields: [declaracionItemId], references: [id], onDelete: Cascade)

  @@map("distribuciones_no_lectivas")
}

// ============================================
// DISPONIBILIDAD Y RESTRICCIONES
// ============================================

model DisponibilidadDocente {
  id          String    @id @default(uuid())
  docenteId   String
  diaSemana   DiaSemana
  horaInicio  String
  horaFin     String
  prioridad   Int       @default(1)
  
  docente     Docente   @relation(fields: [docenteId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([docenteId, diaSemana])
  @@map("disponibilidad_docentes")
}

model RestriccionAmbiente {
  id          String   @id @default(uuid())
  ambienteId  String
  diaSemana   DiaSemana
  horaInicio  String
  horaFin     String
  motivo      String?
  
  ambiente    Ambiente @relation(fields: [ambienteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ambienteId])
  @@map("restricciones_ambientes")
}

model MantenimientoAmbiente {
  id          String    @id @default(uuid())
  ambienteId  String
  fechaInicio DateTime
  fechaFin    DateTime
  descripcion String
  completado  Boolean   @default(false)
  
  ambiente    Ambiente  @relation(fields: [ambienteId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ambienteId, fechaInicio])
  @@map("mantenimientos_ambientes")
}

// ============================================
// VALIDACIONES AUTOMÁTICAS
// ============================================

model ValidacionHorario {
  id          String             @id @default(uuid())
  horarioId   String
  tipoRegla   TipoReglaValidacion
  cumple      Boolean
  mensaje     String?
  metadata    Json?
  
  horario     Horario            @relation(fields: [horarioId], references: [id], onDelete: Cascade)

  createdAt   DateTime           @default(now())

  @@index([horarioId])
  @@index([tipoRegla])
  @@map("validaciones_horarios")
}

// ============================================
// INCUMPLIMIENTOS (Para sanciones)
// ============================================

model Incumplimiento {
  id          String                 @id @default(uuid())
  docenteId   String
  horarioId   String?
  tipoRegla   TipoReglaValidacion
  descripcion String
  estado      EstadoIncumplimiento   @default(DETECTADO)
  detectadoPor String?               // usuarioId que registró (si es manual)
  sancionAplicada String?
  resolucion  String?
  
  docente     Docente                @relation(fields: [docenteId], references: [id])
  horario     Horario?               @relation(fields: [horarioId], references: [id])

  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([docenteId, estado])
  @@index([horarioId])
  @@map("incumplimientos")
}

// ============================================
// VENTANAS DE ATENCIÓN
// ============================================

model VentanaAtencion {
  id            String        @id @default(uuid())
  periodoId     String
  nombre        String
  categorias Json @default("[]")        // Array de categorías en orden de atención (ej: ["PRINCIPAL", "ASOCIADO", ...])
  fechaInicio   DateTime
  fechaFin      DateTime
  estado        EstadoVentana @default(PROGRAMADA)
  
  periodo       PeriodoAcademico @relation(fields: [periodoId], references: [id])
  atenciones    AtencionVentana[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([periodoId, estado])
  @@map("ventanas_atencion")
}

model AtencionVentana {
  id            String          @id @default(uuid())
  ventanaId     String
  docenteId     String
  posicion      Int
  estado        EstadoAtencion  @default(ESPERANDO)
  horaInicio    DateTime?
  horaFin       DateTime?
  
  ventana       VentanaAtencion @relation(fields: [ventanaId], references: [id], onDelete: Cascade)
  docente       Docente         @relation(fields: [docenteId], references: [id])

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([ventanaId, posicion])
  @@index([docenteId, ventanaId])
  @@map("atencion_ventanas")
}

// ============================================
// NOTIFICACIONES
// ============================================

model Notificacion {
  id              String              @id @default(uuid())
  usuarioId       String
  tipo            TipoNotificacion
  titulo          String
  mensaje         String
  prioridad       PrioridadNotificacion @default(MEDIA)
  canal           CanalNotificacion
  estado          EstadoNotificacion  @default(PENDIENTE)
  metadata        Json?
  
  usuario         Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  envios          EnvioNotificacion[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([usuarioId, estado])
  @@index([tipo])
  @@index([createdAt])
  @@map("notificaciones")
}

model EnvioNotificacion {
  id              String            @id @default(uuid())
  notificacionId  String
  canal           CanalNotificacion
  estado          EstadoNotificacion @default(PENDIENTE)
  intento         Int              @default(1)
  error           String?
  enviadoEn       DateTime?
  
  notificacion    Notificacion      @relation(fields: [notificacionId], references: [id], onDelete: Cascade)

  createdAt       DateTime          @default(now())

  @@index([notificacionId])
  @@index([estado])
  @@map("envios_notificaciones")
}

model PreferenciasNotificacion {
  id              String    @id @default(uuid())
  docenteId       String    @unique
  correoActivo    Boolean   @default(true)
  whatsappActivo  Boolean   @default(true)
  telegramActivo  Boolean   @default(true)
  sistemaActivo   Boolean   @default(true)
  frecuenciaMaxDiaria Int  @default(10)
  
  docente         Docente   @relation(fields: [docenteId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("preferencias_notificaciones")
}

// ============================================
// AUDITORÍA Y CONFIGURACIÓN
// ============================================

model RegistroAuditoria {
  id          String   @id @default(uuid())
  usuarioId   String?
  accion      String
  entidad     String
  entidadId   String?
  datos       Json?
  ipAddress   String?
  
  usuario     Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([usuarioId])
  @@index([accion])
  @@index([entidad])
  @@index([createdAt])
  @@map("registros_auditoria")
}

model ConfiguracionPeriodo {
  id                  String    @id @default(uuid())
  periodoId           String    @unique
  horasMaxDiariasDocente Int   @default(8)
  horasMaxContinuas   Int       @default(4)
  descansoMinEntreHoras Int    @default(1)
  ordenCategorias     Json?
  
  periodo             PeriodoAcademico @relation(fields: [periodoId], references: [id], onDelete: Cascade)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("configuraciones_periodo")
}

model DiaNoLaborable {
  id          String   @id @default(uuid())
  fecha       DateTime @unique
  motivo      String
  periodoId   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fecha])
  @@map("dias_no_laborables")
}

// ============================================
// SELECCIONES TEMPORALES (Redis)
// NOTA: Este modelo es solo para referencia/documentación.
// Los datos reales se almacenan en Redis con TTL.
// ============================================

model SeleccionTemporal {
  id          String   @id @default(uuid())
  sessionId   String
  docenteId   String
  periodoId   String
  cursoId     String
  datos       Json
  expiraEn    DateTime
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
  @@index([expiraEn])
  @@map("selecciones_temporales")
}

// ============================================
// ESTUDIANTES Y MATRÍCULA
// ============================================

model Estudiante {
  id              String    @id @default(uuid())
  codigo          String    @unique
  nombre          String
  apellidos       String
  email           String    @unique
  dni             String    @unique
  ciclo           Int       @default(1)
  activo          Boolean   @default(true)
  
  matriculas      Matricula[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([codigo])
  @@index([email])
  @@index([activo])
  @@map("estudiantes")
}

model Matricula {
  id              String    @id @default(uuid())
  estudianteId    String
  cursoId         String
  grupoId         String
  periodoId       String
  estado          String    @default("ACTIVO")
  
  estudiante      Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  curso           Curso      @relation(fields: [cursoId], references: [id])
  grupo           Grupo      @relation(fields: [grupoId], references: [id])
  periodo         PeriodoAcademico @relation(fields: [periodoId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([estudianteId, cursoId, periodoId])
  @@index([estudianteId])
  @@index([grupoId])
  @@index([periodoId])
  @@map("matriculas")
}